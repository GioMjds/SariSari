{
  "expo": {
    "name": "SariSari",
    "slug": "sarisari",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "sarisari",
    "userInterfaceStyle": "light",
    "backgroundColor": "#EFE6D2",
    "runtimeVersion": "1.1.0",
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#EFE6D2",
      "bundleIdentifier": "com.giomjds.sarisari",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EFE6D2",
        "foregroundImage": "./assets/images/logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.giomjds.sarisari"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "./plugins/withAndroidWindowBackground",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#EFE6D2",
          "dark": {
            "backgroundColor": "#EFE6D2"
          }
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#EFE6D2"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SariSari to use the device camera to scan product barcodes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "privacyPolicyUrl": "https://giomjds.github.io/SariSari/",
      "eas": {
        "projectId": "982c08c5-26c3-4edc-b8f3-64830767ef23"
      }
    },
    "owner": "mimic1"
  }
}
